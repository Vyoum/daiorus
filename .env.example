# Supabase Postgres
# Transaction pooler (runtime) — port 6543 — URL-encode special password chars (@ → %40)
DATABASE_URL="postgresql://postgres.mcumqgfanxkyewanapgx:YOUR_PASSWORD@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session / direct URL for Prisma migrate — port 5432
DIRECT_URL="postgresql://postgres.mcumqgfanxkyewanapgx:YOUR_PASSWORD@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres"

# Razorpay — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx

# Optional — for Razorpay webhooks (Dashboard → Webhooks)
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# App URL (used in emails / redirects in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
